head(design)
head(design)
library(limma)
library(Biobase)
load("data/process/eset_final.RData")
load("data/processed/eset_final.RData")
groups <- pData(eset_final)$group
design <- model.matrix(~ 0 + groups)
colnames(design) <- c("Control", "SCA2", "PD")
head(design)
contrast_matrix <- makeContrasts(SCA2_vs_Control = SCA2 - Control, PD_vs_Control = PD - Control, levels = design)
fit <- lmFit(eset_final, design)
fit2 <- contrasts.fit(fit, contrast_matrix)
fit2 <- eBayes(fit2)
summary(decideTests(fit2))
results_SCA2 <- topTable(fit2, coef = "SCA2_vs_Control", n = Inf)
results_PD <- topTable(fit2, coef = "PD_vs_Control", n = Inf)
head(results_SCA2)
head(results_PD)
head(results_SCA2)
# clean up SCA2 results
SCA2_clean <- data.frame(
  Gene = results_SCA2$GENE_SYMBOL,
  logFC = round(results_SCA2$logFC, 3),
  AveExpr = round(results_SCA2$AveExpr, 3),
  P.Value = signif(results_SCA2$P.Value, 3),
  adj.P.Val = signif(results_SCA2$adj.P.Val, 3)
)
# clean up PD results
PD_clean <- data.frame(
  Gene = results_PD$GENE_SYMBOL,
  logFC = round(results_PD$logFC, 3),
  AveExpr = round(results_PD$AveExpr, 3),
  P.Value = signif(results_PD$P.Value, 3),
  adj.P.Val = signif(results_PD$adj.P.Val, 3)
)
# print top results
head(SCA2_clean, 10)
head(PD_clean, 10)
# save results
write.csv(SCA2_clean, file = "results/DEG_SCA2_vs_Control.csv", row.names = FALSE)
write.csv(PD_clean, file = "results/DEG_PD_vs_Control.csv", row.names = FALSE)
# also save the full fitted model for later
save(fit2, file = "data/processed/fit2.RData")
exit
quit
q()
source("setup.R")
library(ggplot2)
library(pheatmap)
results_PD$significant <- ifelse(results_PD$adj.P.Val < 0.05, TRUE, FALSE)
results_SCA2$significant <- ifelse(results_SCA2$adj.P.Val < 0.05, TRUE, FALSE)
sig_genes <- unique(c(
  results_PD$GENE_SYMBOL[results_PD$significant == TRUE],
  results_SCA2$GENE_SYMBOL[results_SCA2$significant == TRUE]
))
expr_mat <- exprs(eset_final)[fData(eset_final)$GENE_SYMBOL %in% sig_genes, ]
rownames(expr_mat) <- fData(eset_final)$GENE_SYMBOL[fData(eset_final)$GENE_SYMBOL %in% sig_genes]
annotation <- data.frame(Group = groups)
rownames(annotation) <- colnames(expr_mat)
