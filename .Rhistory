BiocManager::install("clusterProfiler")
BiocManager::install("org.Hs.eg.db")
library(clusterProfiler)
library(org.Hs.eg.db)
sig_genes_entrez <- bitr(sig_genes, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.Hs.eg.db)
nrow(sig_genes_entrez)
sig_genes_entrez
background_entrez <- bitr(fData(eset_final)$GENE_SYMBOL, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.Hs.eg.db)
save(sig_genes_entrez, background_entrez, pca_result, pca_df, file = "data/processed/progress.RData")
write('load("data/processed/progress.RData")', file = "setup.R", append = TRUE)
q()
source("setup.R")
library(clusterProfiler)
library(org.Hs.eg.db)
ego <- enrichGO(
  gene = sig_genes_entrez$ENTREZID,
  universe = background_entrez$ENTREZID,
  OrgDb = org.Hs.eg.db,
  ont = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff = 0.05
)
summary(ego)
ego <- enrichGO(
  gene = sig_genes_entrez$ENTREZID,
  universe = background_entrez$ENTREZID,
  OrgDb = org.Hs.eg.db,
  ont = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff = 0.2
)

as.data.frame(ego)[, c("Description", "GeneRatio", "pvalue", "p.adjust")]
ego_MF <- enrichGO(
  gene = sig_genes_entrez$ENTREZID,
  universe = background_entrez$ENTREZID,
  OrgDb = org.Hs.eg.db,
  ont = "MF",
  pAdjustMethod = "BH",
  pvalueCutoff = 0.2
)

as.data.frame(ego_MF)[, c("Description", "GeneRatio", "pvalue", "p.adjust")]
ego_noBG <- enrichGO(
  gene = sig_genes_entrez$ENTREZID,
  OrgDb = org.Hs.eg.db,
  ont = "BP",
  pAdjustMethod = "BH",
  pvalueCutoff = 0.2
)

as.data.frame(ego_noBG)[, c("Description", "GeneRatio", "pvalue", "p.adjust")]
png("figures/enrichGO_MF.png", width=900, height=700)
dotplot(ego_MF, showCategory=15, title="GO Molecular Function Enrichment")
dev.off()
save(ego_MF, file = "data/processed/enrichGO_results.RData")
write.csv(as.data.frame(ego_MF), file = "results/enrichGO_MF_results.csv", row.names = FALSE)
