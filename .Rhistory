library(Biobase)
pca_result <- prcomp(t(exprs(eset_final)), scale. = TRUE)
pca_df <- data.frame(
  PC1 = pca_result$x[, 1],
  PC2 = pca_result$x[, 2],
  Group = groups
)
png("figures/PCA_plot.png", width=800, height=600)
ggplot(pca_df, aes(x = PC1, y = PC2)) +
  geom_point(aes(color = Group), size = 3) +
  ggtitle("PCA of Gene Expression — SCA2, PD, and Control")
dev.off()
